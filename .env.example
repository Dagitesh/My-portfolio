# Get a free access key at https://web3forms.com (set notification email in their dashboard).
# Must be NEXT_PUBLIC_* so the form can submit from the browser (free tier does not allow server-side API calls).
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Admin-only login for /gallery/upload + /api/gallery/upload
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Any long random string. Used to sign the admin session cookie.
AUTH_SECRET=
